# Linux-окружение для локального прогона backend Go-тестов.
# На macOS/Windows тесты, завязанные на linux/Keenetic, нужно гонять в контейнере.
#
# Быстрый старт:
#   docker compose -f docker-compose.go-test.yml up -d
#   docker compose -f docker-compose.go-test.yml exec runner go test -count=1 ./internal/managed
#
# Или через обёртку:
#   ./scripts/dev/go-test-docker.sh start
#   ./scripts/dev/go-test-docker.sh run ./internal/managed
#
# Одноразовый прогон без постоянного контейнера:
#   docker compose -f docker-compose.go-test.yml run --rm test ./...

FROM golang:1.24-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
        procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src

ENV GOCACHE=/go-build-cache \
    GOMODCACHE=/go/pkg/mod

ENTRYPOINT ["go", "test", "-count=1"]
CMD ["./..."]
